        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% Node Style Definitions\n    classDef io fill:#5c3a21,stroke:#d79b00,stroke-width:2px,color:#fff;\n    classDef fsm fill:#4d3b00,stroke:#d79b00,stroke-width:2px,color:#fff;\n    classDef sponge fill:#1e3c5a,stroke:#6c8ebf,stroke-width:2px,color:#fff;\n    classDef datapath fill:#1c3d19,stroke:#82b366,stroke-width:2px,color:#fff;\n    classDef statebank fill:#422a4c,stroke:#9673a6,stroke-width:2px,color:#fff;\n\n    %% Global Signals\n    subgraph Global_Signals [\&quot;Global Clocks &amp; Resets\&quot;]\n        CLK([\&quot;clk\&quot;]):::io\n        RST([\&quot;rst_n\&quot;]):::io\n    end\n\n    subgraph FSM_Block [\&quot;Controller\&quot;]\n        FSM[\&quot;Global Low-Power FSM\\n(Absorb / 24-Round / Squeeze Scheduler)\&quot;]:::fsm\n    end\n\n    subgraph Sponge_Wrapper [\&quot;SHA-3 Sponge Wrapper\&quot;]\n        RAW_IN([\&quot;Raw Msg In\&quot;]):::io --&gt; PAD[\&quot;Input FIFO &amp; Padding\\n(10*1 Pad &amp; Domain Separation)\&quot;]:::sponge\n        PAD -- \&quot;padded_data [63:0]\&quot; --&gt; XOR_ABSORB[\&quot;Absorb XOR Logic\&quot;]:::sponge\n        SQUEEZE_OUT[\&quot;Output Formatter\&quot;]:::sponge --&gt; HASH_OUT([\&quot;Hash Result Out\&quot;]):::io\n    end\n\n    subgraph Keccak_Core [\&quot;Keccak 64-bit Lane-Serial ULP Core\&quot;]\n        %% MUX changed back to standard hardware Trapezoid shape\n        XOR_ABSORB -- \&quot;absorb_data [63:0]\&quot; --&gt; MUX_IN[/\&quot;MUX_IN (2-to-1)\&quot;\\]:::datapath\n        \n        MUX_IN -- \&quot;write_data\&quot; --&gt; STATE_BANK[\&quot;1600-bit State Bank\\n(25 x 64-bit Gated Registers)\&quot;]:::statebank\n        \n        %% Squeeze Path\n        STATE_BANK -- \&quot;read_data\&quot; --&gt; SQUEEZE_OUT\n        \n        %% 24-Round Datapath\n        STATE_BANK -- \&quot;read_data (64b / 320b)\&quot; --&gt; THETA[\&quot;Theta Unit\\n(Parity XOR Tree + C/D Regs)\&quot;]:::datapath\n        THETA --&gt; RHO_PI[\&quot;Rho/Pi Unit\\n(Fixed Wire Rotation &amp; Remap MUX)\&quot;]:::datapath\n        RHO_PI --&gt; CHI[\&quot;Chi Unit\\n(Row Temp Reg + Non-linear Logic)\&quot;]:::datapath\n        CHI --&gt; IOTA[\&quot;Iota Unit\\n(Round Constant Injector)\&quot;]:::datapath\n        \n        %% Feedback Loop\n        IOTA -- \&quot;feedback_data\&quot; --&gt; MUX_IN\n        \n        %% Absorb XOR Feedback\n        STATE_BANK -- \&quot;state_feedback\&quot; --&gt; XOR_ABSORB\n    end\n\n    %% Clock and Reset Routing (Solid lines)\n    CLK --&gt; FSM\n    RST --&gt; FSM\n    CLK --&gt; STATE_BANK\n    RST --&gt; STATE_BANK\n    CLK --&gt; THETA\n    RST --&gt; THETA\n    CLK --&gt; CHI\n    RST --&gt; CHI\n\n    %% Control Signals Routing (Solid lines)\n    FSM -- \&quot;mux_sel\&quot; --&gt; MUX_IN\n    FSM -- \&quot;lane_write_en [24:0]\\n(Clock Gating)\&quot; --&gt; STATE_BANK\n    FSM -- \&quot;read_addr / write_addr\&quot; --&gt; STATE_BANK\n    FSM -- \&quot;datapath_ctrl\\n(Reg Enable)\&quot; --&gt; THETA\n    FSM -- \&quot;datapath_ctrl\\n(Reg Enable)\&quot; --&gt; CHI\n    FSM -- \&quot;round_const [63:0]\&quot; --&gt; IOTA\n\n    %% Force all lines to be solid white-ish to avoid dark-mode inversion\n    linkStyle default stroke:#fffffe,stroke-width:3px,fill:none;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="SRg6l3N4BOvvE8hANFO8-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
